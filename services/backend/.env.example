# Copy this file to .env and fill in your values.
# The backend works WITHOUT an API key (falls back to mock AI responses).

# Anthropic Claude API key (optional – leave blank to use mock AI)
ANTHROPIC_API_KEY=

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Server host/port
HOST=0.0.0.0
PORT=8000

# CORS: comma-separated origins to allow (use * for open demo)
CORS_ORIGINS=*

# SQLite database file path
DB_PATH=./otter_records.db
