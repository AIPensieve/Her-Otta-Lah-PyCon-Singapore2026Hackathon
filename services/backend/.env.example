# Copy this file to .env and fill in your values.
# The backend works WITHOUT an API key (falls back to mock AI responses).

# ── Demo Mode ────────────────────────────────────────────────────────────────
# DEMO_MODE=true  → guaranteed stable; auto-fallback to mock on any error
# DEMO_MODE=false → production mode
DEMO_MODE=true

# AI_MODE=mock    → keyword rules only, never calls OpenAI API
# AI_MODE=real    → try OpenAI first, fallback to mock on any error
AI_MODE=mock

# ── OpenAI API (required for AI_MODE=real) ───────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS: comma-separated origins (use * for open demo) ─────────────────────
CORS_ORIGINS=*

# ── SQLite database ───────────────────────────────────────────────────────────
DB_PATH=./otter_records.db
