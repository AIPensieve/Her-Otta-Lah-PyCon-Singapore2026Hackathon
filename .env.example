# AI Otter Coach — Environment Variables Template
# Copy to .env and fill in your values. Never commit .env.

# ── AI Backend ────────────────────────────────────────────────────────────────
# Set to "real" to use OpenAI API, "mock" for deterministic demo responses
AI_MODE=mock
OPENAI_API_KEY=sk-proj-...your-key-here...
OPENAI_MODEL=gpt-4o

# ── Voice (optional) ──────────────────────────────────────────────────────────
# ElevenLabs for text-to-speech (optional, demo works without it)
ELEVENLABS_API_KEY=...your-key-here...

# ── Backend server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Demo mode ────────────────────────────────────────────────────────────────
# DEMO_MODE=true guarantees mock fallback even if API key is present
DEMO_MODE=true

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./otter_records.db
